{
	"name": "cs2parser-native",
	"version": "0.1.0",
	"private": true,
	"description": "Rust hot path for cs2parser. Built and consumed via @napi-rs/cli; not published standalone.",
	"main": "index.js",
	"types": "index.d.ts",
	"napi": {
		"name": "cs2parser-native",
		"triples": {
			"defaults": false,
			"additional": [
				"x86_64-pc-windows-msvc",
				"x86_64-unknown-linux-gnu",
				"x86_64-unknown-linux-musl",
				"aarch64-unknown-linux-gnu",
				"x86_64-apple-darwin",
				"aarch64-apple-darwin"
			]
		}
	},
	"scripts": {
		"build": "napi build --platform --release",
		"build:debug": "napi build --platform"
	},
	"devDependencies": {
		"@napi-rs/cli": "^2.18.4"
	}
}
