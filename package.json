{
	"version": "2.2.0-alpha.0",
	"name": "cs2parser",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/osztenkurden/cs2parser.git"
	},
	"bugs": {
		"url": "https://github.com/osztenkurden/cs2parser/issues"
	},
	"homepage": "https://github.com/osztenkurden/cs2parser#readme",
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.0",
		"cs2parser-native": "2.0.0-alpha.0",
		"snappy": "^7.3.3"
	},
	"license": "GPL-3.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"./dist",
		"ACKNOWLEDGEMENTS"
	],
	"types": "./dist/index.d.mts",
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"workspaces": [
		"crates/native"
	],
	"scripts": {
		"typecheck": "tsgo",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"build:native": "npm --workspace cs2parser-native run build",
		"build:native:debug": "npm --workspace cs2parser-native run build:debug",
		"build": "npm run typecheck && tsdown",
		"test": "bun test --timeout 300000",
		"test:watch": "bun test --watch --timeout 300000",
		"test:coverage": "bun test --coverage --timeout 300000",
		"prepublishOnly": "npm run lint && npm run format:check && npm run build",
		"prepare": "husky",
		"generate:entities": "bun scripts/generate-entity-types.ts",
		"generate:events": "bun scripts/generate-event-types.ts",
		"generate:protos": "bun scripts/generate-protos.ts",
		"generate:descriptors": "bun scripts/dump-event-descriptors.ts",
		"generate": "bun scripts/generate-protos.ts && bun scripts/generate-entity-types.ts --snapshot",
		"benchmark": "bun --expose-gc scripts/benchmark.ts",
		"benchmark:readme": "bun scripts/benchmark-readme.ts",
		"sync-versions": "bun scripts/sync-package-versions.ts"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/bun": "^1.3.14",
		"@types/bytebuffer": "^5.0.49",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.19.19",
		"@types/varint": "^6.0.3",
		"@typescript/native-preview": "^7.0.0-dev.20260515.1",
		"del-cli": "^5.1.0",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"prettier": "^3.8.3",
		"ts-proto": "2.11.6",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	}
}
