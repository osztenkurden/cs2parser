{
	"version": "1.0.1",
	"name": "cs2parser",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/osztenkurden/cs2parser.git"
	},
	"bugs": {
		"url": "https://github.com/osztenkurden/cs2parser/issues"
	},
	"homepage": "https://github.com/osztenkurden/cs2parser#readme",
	"dependencies": {
		"@bufbuild/protobuf": "^2.10.0",
		"bytebuffer": "^5.0.1",
		"fs-extra": "^11.2.0",
		"protobufjs": "^7.2.4",
		"snappy": "^7.3.3"
	},
	"license": "GPL-3.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"typecheck": "tsc",
		"clean": "del-cli dist",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"format": "prettier --write src/",
		"format:check": "prettier --check src/",
		"build": "npm run clean && npm run typecheck && tsup src/index.ts --format esm --dts -d dist",
		"test": "bun test --timeout 300000",
		"test:watch": "bun test --watch --timeout 300000",
		"test:coverage": "bun test --coverage --timeout 300000",
		"prepublishOnly": "npm run lint && npm run format:check && npm run build",
		"prepare": "husky",
		"generate:entities": "bun scripts/generate-entity-types.ts",
		"generate:events": "bun scripts/generate-event-types.ts",
		"generate:protos": "bun scripts/generate-protos.ts",
		"generate": "bun scripts/generate-protos.ts && bun scripts/generate-entity-types.ts --snapshot",
		"benchmark": "bun --expose-gc scripts/benchmark.ts"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/bun": "^1.3.11",
		"@types/bytebuffer": "^5.0.49",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^22.17.2",
		"@types/varint": "^6.0.1",
		"del-cli": "^5.1.0",
		"eslint": "^9.36.0",
		"husky": "^9.1.7",
		"prettier": "^3.0.3",
		"ts-proto": "2.11.6",
		"tsup": "^8.2.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.45.0"
	}
}
